{
  "name": "gofish-graphics-monorepo",
  "version": "0.0.22",
  "description": "GoFish Graphics monorepo",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter gofish-graphics dev",
    "build": "pnpm --filter gofish-graphics build",
    "build:widget": "pnpm --filter gofish-python build:widget",
    "docs:dev": "pnpm --filter docs docs:dev",
    "docs:build": "pnpm --filter docs docs:build",
    "docs:preview": "pnpm --filter docs docs:preview",
    "storybook": "pnpm --filter gofish-graphics storybook",
    "build-storybook": "pnpm --filter gofish-graphics build-storybook",
    "chromatic": "pnpm exec chromatic",
    "test": "pnpm --filter gofish-graphics test",
    "test:path": "pnpm --filter gofish-graphics test:path",
    "test:font": "pnpm --filter gofish-graphics test:font",
    "test:visual": "pnpm --filter @gofish/tests test",
    "test:visual:update": "pnpm --filter @gofish/tests update",
    "test:visual:js": "pnpm --filter @gofish/tests test:js",
    "test:visual:review": "pnpm --filter @gofish/tests review",
    "test:visual:check-sync": "pnpm --filter @gofish/tests check-sync",
    "test:visual:python": "pnpm --filter @gofish/tests test:python",
    "test:visual:capture-python": "pnpm --filter @gofish/tests capture-python",
    "test:visual:compare-python": "pnpm --filter @gofish/tests compare-python",
    "test:visual:check-python-sync": "pnpm --filter @gofish/tests check-python-sync",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "chromatic": "^13.3.5",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.56.1"
  }
}
